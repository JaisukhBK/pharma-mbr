# ============================================================================
# PharmaMES.AI — Server Environment (Segment 1)
# Copy to .env and fill in your values. Never commit .env to git.
# ============================================================================

PORT=5000
NODE_ENV=development

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@your_host.neon.tech/pharmames?sslmode=require

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex')|pbcopy"
# MUST be set — server will refuse to start without it.
JWT_SECRET=replace_with_64_byte_hex_secret_generated_locally

# Token lifetimes
ACCESS_TOKEN_TTL_MIN=15        # access token: 15 minutes (21 CFR §11.10(g))
REFRESH_TOKEN_TTL_DAYS=7       # refresh token: 7 days

# ── AI (Groq) ────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys
# DO NOT commit real keys — add .env to .gitignore
GROQ_API_KEY=

# ── Session / Security ───────────────────────────────────────────────────────
SESSION_SECRET=replace_with_another_random_secret

# Account lockout (21 CFR Part 11 §11.10(d))
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# Password policy
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_COUNT=12

# ── Client origin (production only) ─────────────────────────────────────────
# CLIENT_ORIGIN=https://your-frontend-domain.com
